{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ravatex.local/governance/unit4-rollback-readiness.schema.json",
  "title": "Unit 4C forward-correction readiness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "package_id", "status", "accepted_pre_cutover_checkpoint",
    "defective_authority_epoch", "required_corrective_authority_epoch",
    "prior_authority_owners", "current_structured_owners", "generated_root_paths",
    "governing_bootstrap_consumers", "requirements", "prohibitions",
    "actual_unit4c_commit_checkpoint"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "package_id": { "const": "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-4C-ROLLBACK-READINESS-R1" },
    "status": { "const": "PREPARED / NOT AUTHORIZED / NOT ACTIVATED" },
    "accepted_pre_cutover_checkpoint": { "const": "fa986cf935abbf053172cfd549b0171bb9446f58" },
    "defective_authority_epoch": { "const": 1 },
    "required_corrective_authority_epoch": { "const": 2 },
    "prior_authority_owners": { "type": "array", "minItems": 4, "maxItems": 4 },
    "current_structured_owners": { "type": "array", "minItems": 3, "maxItems": 3 },
    "generated_root_paths": { "type": "array", "minItems": 4, "maxItems": 4 },
    "governing_bootstrap_consumers": { "type": "array", "minItems": 3 },
    "requirements": { "type": "array", "minItems": 6 },
    "prohibitions": { "type": "array", "minItems": 7 },
    "actual_unit4c_commit_checkpoint": { "const": "EXTERNALLY_REQUIRED_INPUT" }
  }
}
