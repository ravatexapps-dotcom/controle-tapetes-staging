{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ravatex.local/governance/purchase-order-phase-c-v2.schema.json",
  "title": "Unit 4 governed Phase-C traceability lifecycle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "mode", "authority", "activation_status",
    "future_authority_path", "canonical_source", "requirements"
  ],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "mode": { "enum": ["CUTOVER_CANDIDATE", "CANONICAL"] },
    "authority": { "enum": ["NON_CANONICAL_UNTIL_SUPERVISOR_ACTIVATION", "CANONICAL_PHASE_C_TRACEABILITY_OWNER"] },
    "activation_status": { "enum": ["INACTIVE", "ACTIVE"] },
    "authority_epoch": { "const": 1 },
    "cutover_id": { "const": "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-4C-AUTHORITY-CUTOVER-R1" },
    "future_authority_path": { "const": "docs/governance/traceability/purchase-order-phase-c.json" },
    "canonical_source": { "const": "docs/architecture/ORDEM_COMPRA_C3_TRACEABILITY.md" },
    "requirements": {
      "type": "array",
      "minItems": 13,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "requirement_id", "normative_sources", "disposition",
          "evidence_pointers", "phase_owner", "blocking_state",
          "source_location", "canonical_row_sha256", "review_status", "review_basis"
        ],
        "properties": {
          "requirement_id": { "type": "string", "pattern": "^OC-[A-Z0-9-]+$" },
          "normative_sources": { "type": "array", "minItems": 1 },
          "disposition": { "type": "string", "minLength": 1 },
          "evidence_pointers": { "type": "array" },
          "phase_owner": { "type": "string", "minLength": 1 },
          "blocking_state": { "type": "string", "minLength": 1 },
          "source_location": { "type": "string", "pattern": "^docs/architecture/ORDEM_COMPRA_C3_TRACEABILITY\\.md:\\d+$" },
          "canonical_row_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "review_status": { "const": "REVIEWED" },
          "review_basis": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "mode": { "const": "CANONICAL" } } },
      "then": {
        "required": ["authority_epoch", "cutover_id"],
        "properties": {
          "authority": { "const": "CANONICAL_PHASE_C_TRACEABILITY_OWNER" },
          "activation_status": { "const": "ACTIVE" }
        }
      },
      "else": {
        "properties": {
          "authority": { "const": "NON_CANONICAL_UNTIL_SUPERVISOR_ACTIVATION" },
          "activation_status": { "const": "INACTIVE" }
        }
      }
    }
  ]
}
