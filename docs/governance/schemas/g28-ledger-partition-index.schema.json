{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ravatex.local/governance/g28-ledger-partition-index.schema.json",
  "title": "G28 non-canonical ledger partition index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "index_id", "authority", "canonical_source", "canonical_source_git_object", "canonical_source_sha256", "canonical_byte_count", "canonical_line_count", "source_manifest_path", "preamble_unit_id", "thresholds", "source_units", "partitions", "unit_to_partition", "inbound_reference_survival_mappings", "compatibility_view", "complete_reassembly_sha256"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "index_id": { "const": "G28-LEDGER-PARTITION-INDEX-R1" },
    "authority": { "const": "NON-CANONICAL_SHADOW; CANONICAL_LEDGER_AUTHORITY_UNCHANGED" },
    "canonical_source": { "const": "docs/ledgers/G28_LEDGER.md" },
    "canonical_source_git_object": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "canonical_source_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "canonical_byte_count": { "type": "integer", "minimum": 1 },
    "canonical_line_count": { "type": "integer", "minimum": 1 },
    "source_manifest_path": { "const": "docs/governance/ledger/g28-ledger-source-manifest.json" },
    "preamble_unit_id": { "const": "G28-LEDGER-PREAMBLE" },
    "thresholds": { "type": "object", "additionalProperties": false, "required": ["max_source_lines", "max_source_bytes"], "properties": { "max_source_lines": { "const": 1000 }, "max_source_bytes": { "const": 131072 } } },
    "source_units": { "type": "array", "minItems": 2 },
    "partitions": { "type": "array", "minItems": 1 },
    "unit_to_partition": { "type": "array", "minItems": 2 },
    "inbound_reference_survival_mappings": { "type": "array" },
    "compatibility_view": { "type": "object", "additionalProperties": false, "required": ["path", "reconstructed_from", "payload_sha256"], "properties": { "path": { "const": "docs/governance/shadow/generated/G28_LEDGER.md" }, "reconstructed_from": { "const": "ORDERED_PARTITION_PAYLOADS" }, "payload_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" } } },
    "complete_reassembly_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
