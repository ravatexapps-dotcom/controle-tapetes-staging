{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ravatex.local/governance/g28-ledger-partition-index.schema.json",
  "title": "G28 non-canonical ledger partition index",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "index_id", "authority", "canonical_source", "canonical_source_git_object", "canonical_source_sha256", "canonical_byte_count", "canonical_line_count", "source_manifest_path", "preamble_unit_id", "thresholds", "source_units", "partitions", "unit_to_partition", "inbound_reference_survival_mappings", "compatibility_view", "complete_reassembly_sha256"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "index_id": { "const": "G28-LEDGER-PARTITION-INDEX-R1" },
    "authority": { "const": "NON-CANONICAL_SHADOW; CANONICAL_LEDGER_AUTHORITY_UNCHANGED" },
    "canonical_source": { "const": "docs/ledgers/G28_LEDGER.md" },
    "canonical_source_git_object": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "canonical_source_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "canonical_byte_count": { "type": "integer", "minimum": 1 },
    "canonical_line_count": { "type": "integer", "minimum": 1 },
    "source_manifest_path": { "const": "docs/governance/ledger/g28-ledger-source-manifest.json" },
    "preamble_unit_id": { "const": "G28-LEDGER-PREAMBLE" },
    "thresholds": { "type": "object", "additionalProperties": false, "required": ["max_source_lines", "max_source_bytes"], "properties": { "max_source_lines": { "const": 1000 }, "max_source_bytes": { "const": 131072 } } },
    "source_units": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/source_unit" } },
    "partitions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/partition" } },
    "unit_to_partition": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/unit_mapping" } },
    "inbound_reference_survival_mappings": { "type": "array", "items": { "$ref": "#/$defs/inbound_mapping" } },
    "compatibility_view": { "type": "object", "additionalProperties": false, "required": ["path", "reconstructed_from", "payload_sha256"], "properties": { "path": { "const": "docs/governance/shadow/generated/G28_LEDGER.md" }, "reconstructed_from": { "const": "ORDERED_PARTITION_PAYLOADS" }, "payload_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" } } },
    "complete_reassembly_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "$defs": {
    "source_unit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit_id", "ordinal", "unit_kind", "heading", "date", "phase_order_id", "start_byte", "end_byte", "start_line", "end_line", "raw_sha256", "byte_count", "line_count"],
      "properties": {
        "unit_id": { "type": "string", "pattern": "^(G28-LEDGER-PREAMBLE|G28-LEDGER-UNIT-[0-9]{4})$" },
        "ordinal": { "type": "integer", "minimum": 0 },
        "unit_kind": { "enum": ["PREAMBLE", "ENTRY"] },
        "heading": { "type": ["string", "null"] },
        "date": { "type": ["string", "null"] },
        "phase_order_id": { "type": ["string", "null"] },
        "start_byte": { "type": "integer", "minimum": 0 },
        "end_byte": { "type": "integer", "minimum": 1 },
        "start_line": { "type": "integer", "minimum": 1 },
        "end_line": { "type": "integer", "minimum": 1 },
        "raw_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "byte_count": { "type": "integer", "minimum": 1 },
        "line_count": { "type": "integer", "minimum": 1 }
      }
    },
    "partition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["partition_id", "file_name", "first_unit_ordinal", "last_unit_ordinal", "first_unit_id", "last_unit_id", "start_byte", "end_byte", "start_line", "end_line", "byte_count", "line_count", "oversized_single_unit", "status", "unit_ids", "payload_sha256"],
      "properties": {
        "partition_id": { "type": "string", "pattern": "^G28-LEDGER-PART-[0-9]{4}$" },
        "file_name": { "type": "string", "pattern": "^G28_LEDGER_PART_[0-9]{4}\\.md$" },
        "first_unit_ordinal": { "type": "integer", "minimum": 0 },
        "last_unit_ordinal": { "type": "integer", "minimum": 0 },
        "first_unit_id": { "type": "string", "pattern": "^(G28-LEDGER-PREAMBLE|G28-LEDGER-UNIT-[0-9]{4})$" },
        "last_unit_id": { "type": "string", "pattern": "^(G28-LEDGER-PREAMBLE|G28-LEDGER-UNIT-[0-9]{4})$" },
        "start_byte": { "type": "integer", "minimum": 0 },
        "end_byte": { "type": "integer", "minimum": 1 },
        "start_line": { "type": "integer", "minimum": 1 },
        "end_line": { "type": "integer", "minimum": 1 },
        "byte_count": { "type": "integer", "minimum": 1 },
        "line_count": { "type": "integer", "minimum": 1 },
        "oversized_single_unit": { "type": "boolean" },
        "status": { "enum": ["CLOSED", "OPEN"] },
        "unit_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^(G28-LEDGER-PREAMBLE|G28-LEDGER-UNIT-[0-9]{4})$" } },
        "payload_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "unit_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit_id", "partition_id"],
      "properties": {
        "unit_id": { "type": "string", "pattern": "^(G28-LEDGER-PREAMBLE|G28-LEDGER-UNIT-[0-9]{4})$" },
        "partition_id": { "type": "string", "pattern": "^G28-LEDGER-PART-[0-9]{4}$" }
      }
    },
    "inbound_mapping": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mapping_id", "source_document", "source_line", "reference_kind", "original_target", "anchor", "line_suffix", "resolved_canonical_unit_id", "resolved_partition_id", "compatibility_view_destination", "resolution_status"],
      "properties": {
        "mapping_id": { "type": "string", "pattern": "^G28-LEDGER-REF-[0-9]{4}$" },
        "source_document": { "type": "string", "minLength": 1 },
        "source_line": { "type": "integer", "minimum": 1 },
        "reference_kind": { "type": "string", "minLength": 1 },
        "original_target": { "const": "docs/ledgers/G28_LEDGER.md" },
        "anchor": { "type": ["string", "null"] },
        "line_suffix": { "type": ["string", "null"] },
        "resolved_canonical_unit_id": { "type": ["string", "null"] },
        "resolved_partition_id": { "type": ["string", "null"] },
        "compatibility_view_destination": { "const": "docs/governance/shadow/generated/G28_LEDGER.md" },
        "resolution_status": { "enum": ["COMPATIBILITY_VIEW", "ANCHOR_RESOLVED", "LINE_SUFFIX_RESOLVED"] }
      }
    }
  }
}
