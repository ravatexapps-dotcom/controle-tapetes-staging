{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ravatex.local/governance/unit4-cutover-manifest.schema.json",
  "title": "Unit 4C documentary-authority cutover manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "manifest_id", "contract_id", "order_id", "required_parent",
    "accepted_unit4b_checkpoint", "target_branch", "allowed_remote", "cutover_id",
    "authority_epoch", "activation_status", "state_payload_sha256",
    "activation_manifest_sha256", "current_state_file_sha256", "catalog_sha256",
    "traceability_sha256", "schema_hashes", "generated_root_hashes",
    "governing_artifact_hashes", "canonical_ledger_identity",
    "bounded_ledger_reference_identities", "rollback_readiness_sha256",
    "changed_paths", "ponr_command", "actual_activation_commit_identity",
    "unit4d_review", "prohibited_actions"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "manifest_id": { "const": "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-4C-CUTOVER-MANIFEST-R1" },
    "contract_id": { "const": "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-4-AUTHORITY-CUTOVER-CONTRACT-R1" },
    "order_id": { "const": "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-4C-DOCUMENTARY-AUTHORITY-CUTOVER-R1" },
    "required_parent": { "const": "fa986cf935abbf053172cfd549b0171bb9446f58" },
    "accepted_unit4b_checkpoint": { "const": "fa986cf935abbf053172cfd549b0171bb9446f58" },
    "target_branch": { "const": "dev" },
    "allowed_remote": { "const": "staging/dev" },
    "cutover_id": { "const": "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-4C-AUTHORITY-CUTOVER-R1" },
    "authority_epoch": { "const": 1 },
    "activation_status": { "const": "active" },
    "state_payload_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "activation_manifest_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "current_state_file_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "catalog_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "traceability_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "schema_hashes": { "type": "object", "minProperties": 5 },
    "generated_root_hashes": { "type": "object", "minProperties": 4, "maxProperties": 4 },
    "governing_artifact_hashes": { "type": "object", "minProperties": 4 },
    "canonical_ledger_identity": { "type": "object", "minProperties": 3 },
    "bounded_ledger_reference_identities": { "type": "array", "minItems": 4 },
    "rollback_readiness_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "changed_paths": { "type": "array", "minItems": 1 },
    "ponr_command": { "const": "git push staging dev" },
    "actual_activation_commit_identity": { "const": "EXTERNAL_GIT_FACT" },
    "unit4d_review": { "const": "DIRECT_SUPERVISOR_REVIEW_REQUIRED / NOT_SELF_ACCEPTED" },
    "prohibited_actions": { "type": "array", "minItems": 1 }
  }
}
