{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ravatex.local/governance/current-state-v2.schema.json",
  "title": "Unit 4 governed current-state lifecycle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "mode", "authority", "state_id", "authority_epoch",
    "cutover_id", "last_accepted_phase", "repository", "accepted_checkpoints",
    "phase_status", "active_phase", "next_authorizable_action", "active_track",
    "governing_pointers", "applicable_baseline", "environment_boundaries",
    "protected_residue", "live_debts", "active_requirements", "prohibitions",
    "bounded_recent_ledger_references", "structured_sources",
    "candidate_views", "root_authorities", "rollback_readiness", "activation"
  ],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "mode": { "enum": ["cutover_candidate", "canonical"] },
    "authority": { "enum": ["non_canonical_until_supervisor_activation", "canonical_current_state"] },
    "state_id": { "enum": ["GOVERNANCE-EFFICIENCY-REFOUNDATION-CURRENT-STATE-CANDIDATE-R1", "GOVERNANCE-EFFICIENCY-REFOUNDATION-CURRENT-STATE-R1"] },
    "authority_epoch": { "enum": [0, 1] },
    "cutover_id": { "const": "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-4C-AUTHORITY-CUTOVER-R1" },
    "last_accepted_phase": { "const": "PHASE-C5" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "canonical_workspace", "standalone_git_expected", "branch", "checkpoint_remote"],
      "properties": {
        "identity": { "const": "ravatexapps-dotcom/controle-tapetes-staging" },
        "canonical_workspace": { "const": "D:\\Programação\\controle-tapetes-g28" },
        "standalone_git_expected": { "const": true },
        "branch": { "const": "dev" },
        "checkpoint_remote": { "const": "staging/dev" }
      }
    },
    "accepted_checkpoints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product", "clean_slate_readiness", "clean_slate_execution",
        "governance_unit_1", "governance_unit_2", "governance_unit_3",
        "unit_4_contract"
      ],
      "properties": {
        "product": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "clean_slate_readiness": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "clean_slate_execution": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "governance_unit_1": { "const": "39abf42a7341b61fd4ac02a8e38d1e4f33471f0f" },
        "governance_unit_2": { "const": "f7106977f4613de1830bef46002dbf0a4b8b3cbe" },
        "governance_unit_3": { "const": "53899e30b72cde3d1f5759ea59fb0a4d632c974d" },
        "unit_4_contract": { "const": "76f52c842678b74e655ef9080f4fc67ccbd38e22" },
        "unit_4a_readiness": { "const": "fa986cf935abbf053172cfd549b0171bb9446f58" },
        "unit_4b_readiness": { "const": "fa986cf935abbf053172cfd549b0171bb9446f58" },
        "unit_4c_activation": { "const": "51a61ddfdbf058887ead64f9b018c30ebc371b48" },
        "unit_4c_canonical_correction": { "const": "7abaff26559c71b62337356eccd0baaf36b5f214" },
        "unit_4d_acceptance": { "const": "7abaff26559c71b62337356eccd0baaf36b5f214" }
      }
    },
    "phase_status": { "type": "object", "minProperties": 7 },
    "active_phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "contract", "status"],
      "properties": {
        "id": { "const": "GOVERNANCE-EFFICIENCY-REFOUNDATION" },
        "contract": { "const": "docs/governance/GOVERNANCE_EFFICIENCY_REFOUNDATION_PHASE_CONTRACT.md" },
        "status": { "enum": ["IMPLEMENTED / CUTOVER READINESS EVIDENCE COMPLETE / AWAITING DIRECT SUPERVISOR REVIEW", "UNIT 4C DOCUMENTARY AUTHORITY ACTIVATED / AWAITING DIRECT SUPERVISOR REVIEW", "UNIT 4C FORWARD CORRECTION APPLIED / AWAITING DIRECT SUPERVISOR REVIEW", "UNIT 4 CLOSED / UNIT 5 DIAGNOSIS NEXT AUTHORIZABLE", "UNIT 4 CLOSED / UNIT 5 DIAGNOSIS PRECONDITION CORRECTED / R2 NEXT AUTHORIZABLE"] }
      }
    },
    "next_authorizable_action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["order_id", "canonical_value", "mode", "risk_class", "status"],
      "properties": {
        "order_id": { "enum": ["GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-4A-CUTOVER-READINESS-IMPLEMENTATION-R1", "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-4C-DOCUMENTARY-AUTHORITY-CUTOVER-R1", "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-4C-CANONICAL-CONSISTENCY-FORWARD-CORRECTION-R1", "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-5-LEGACY-DEPRECATION-AND-POST-CUTOVER-AUDIT-DIAGNOSIS-R1", "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-5-LEGACY-DEPRECATION-AND-POST-CUTOVER-AUDIT-DIAGNOSIS-R2"] },
        "canonical_value": { "enum": ["DIRECT SUPERVISOR REVIEW OF GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-4A-CUTOVER-READINESS-IMPLEMENTATION-R1", "DIRECT SUPERVISOR REVIEW OF GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-4C-DOCUMENTARY-AUTHORITY-CUTOVER-R1", "DIRECT SUPERVISOR REVIEW OF GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-4C-CANONICAL-CONSISTENCY-FORWARD-CORRECTION-R1", "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-5-LEGACY-DEPRECATION-AND-POST-CUTOVER-AUDIT-DIAGNOSIS-R1", "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-5-LEGACY-DEPRECATION-AND-POST-CUTOVER-AUDIT-DIAGNOSIS-R2"] },
        "mode": { "enum": ["UNIT 4B READINESS DIRECT REVIEW", "UNIT 4D POST-CUTOVER DIRECT REVIEW", "UNIT 4D POST-CORRECTION DIRECT REVIEW", "READ_ONLY_DIAGNOSIS"] },
        "risk_class": { "enum": ["R1", "R2"] },
        "status": { "enum": ["DIRECT SUPERVISOR REVIEW REQUIRED", "AUTHORIZABLE / NOT AUTHORIZED BY THIS CLOSEOUT", "AUTHORIZABLE AFTER DIRECT REVIEW / UNIT 5 IMPLEMENTATION NOT AUTHORIZED"] }
      }
    },
    "active_track": { "const": "PURCHASE_ORDER_PHASE_C" },
    "governing_pointers": { "type": "object", "minProperties": 8 },
    "applicable_baseline": { "type": "null" },
    "environment_boundaries": { "type": "object", "minProperties": 3 },
    "protected_residue": { "type": "array", "minItems": 3 },
    "live_debts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["owner_path"],
        "properties": {
          "owner_path": { "const": "docs/governance/current-state.json" }
        }
      }
    },
    "current_fact_sections": { "type": "array", "minItems": 8 },
    "historical_fact_sources": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_path", "evidence_role", "evidence_identity", "record_kind",
          "record_count", "unresolved_count", "authority_status", "bootstrap_required"
        ],
        "properties": {
          "source_path": { "type": "string", "pattern": "^(docs/governance/(shadow|candidate)/current-state-equivalence\\.json|docs/closeouts/PROJECT_STATE_ARCHIVE_2026-07\\.md|docs/ledgers/G28_LEDGER\\.md)$" },
          "evidence_role": { "type": "string", "minLength": 1 },
          "evidence_identity": { "type": "string", "minLength": 1 },
          "record_kind": { "enum": ["MAPPING", "UNIT"] },
          "record_count": { "type": "integer", "minimum": 1 },
          "unresolved_count": { "const": 0 },
          "authority_status": { "enum": ["HISTORICAL_NON_AUTHORITATIVE", "CANONICAL_APPEND_ONLY_HISTORY_NON_AUTHORITATIVE_FOR_CURRENT_STATE"] },
          "bootstrap_required": { "const": false }
        }
      }
    },
    "active_requirements": { "type": "array", "minItems": 13 },
    "prohibitions": { "type": "array", "minItems": 1 },
    "bounded_recent_ledger_references": { "type": "array", "minItems": 3 },
    "structured_sources": { "type": "object", "minProperties": 4 },
    "candidate_views": { "type": "object", "minProperties": 4 },
    "root_authorities": { "type": "array", "minItems": 4 },
    "rollback_readiness": { "type": "object", "minProperties": 4 },
    "evidence_events": { "type": "array", "minItems": 3 },
    "activation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status", "target_schema_version", "authority_epoch", "cutover_id",
        "required_parent", "accepted_unit4b_readiness_checkpoint", "branch",
        "allowed_publication_remote", "manifest_algorithm", "state_payload_sha256",
        "structured_source_hashes", "generated_view_hashes",
        "governing_artifact_hashes", "bounded_ledger_reference_identities",
        "activation_manifest_sha256", "rollback_readiness_sha256"
      ],
      "properties": {
        "status": { "enum": ["inactive", "active"] },
        "target_schema_version": { "const": "2.0.0" },
        "authority_epoch": { "enum": [0, 1] },
        "cutover_id": { "const": "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-4C-AUTHORITY-CUTOVER-R1" },
        "required_parent": { "type": ["string", "null"], "pattern": "^[0-9a-f]{40}$" },
        "accepted_unit4b_readiness_checkpoint": { "type": ["string", "null"], "pattern": "^[0-9a-f]{40}$" },
        "branch": { "const": "dev" },
        "allowed_publication_remote": { "const": "staging/dev" },
        "manifest_algorithm": { "const": "UNIT4-ACTIVATION-MANIFEST-V1" },
        "state_payload_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "structured_source_hashes": { "type": "object", "minProperties": 4 },
        "generated_view_hashes": { "type": "object", "minProperties": 4, "maxProperties": 4 },
        "governing_artifact_hashes": { "type": "object", "minProperties": 4 },
        "bounded_ledger_reference_identities": { "type": "array", "minItems": 3 },
        "rollback_readiness_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "activation_manifest_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "mode": { "const": "canonical" } } },
      "then": {
        "required": ["evidence_events", "historical_fact_sources"],
        "not": { "required": ["current_fact_sections"] },
        "properties": {
          "authority": { "const": "canonical_current_state" },
          "state_id": { "const": "GOVERNANCE-EFFICIENCY-REFOUNDATION-CURRENT-STATE-R1" },
          "authority_epoch": { "const": 1 },
          "activation": {
            "properties": {
              "status": { "const": "active" },
              "authority_epoch": { "const": 1 },
              "required_parent": { "const": "fa986cf935abbf053172cfd549b0171bb9446f58" },
              "accepted_unit4b_readiness_checkpoint": { "const": "fa986cf935abbf053172cfd549b0171bb9446f58" }
            }
          }
        }
      },
      "else": {
        "required": ["current_fact_sections"],
        "properties": {
          "authority": { "const": "non_canonical_until_supervisor_activation" },
          "authority_epoch": { "const": 0 },
          "activation": { "properties": { "status": { "const": "inactive" }, "authority_epoch": { "const": 0 } } }
        }
      }
    },
    {
      "if": {
        "properties": {
          "accepted_checkpoints": {
            "required": ["unit_4d_acceptance"]
          }
        }
      },
      "then": {
        "properties": {
          "accepted_checkpoints": {
            "required": [
              "unit_4c_activation",
              "unit_4c_canonical_correction",
              "unit_4d_acceptance"
            ]
          },
          "authority_epoch": { "const": 1 },
          "phase_status": {
            "type": "object",
            "required": [
              "unit_4_contract",
              "unit4a",
              "unit4b",
              "unit4c",
              "unit4d",
              "documentary_authority_cutover",
              "unit5"
            ],
            "properties": {
              "unit_4_contract": { "const": "CLOSED / ACCEPTED / DIRECTLY VERIFIED" },
              "unit4a": { "const": "CLOSED / ACCEPTED / DIRECTLY VERIFIED" },
              "unit4b": { "const": "DIRECT REVIEW COMPLETED / ACCEPTED" },
              "unit4c": { "const": "CLOSED / ACCEPTED / DIRECTLY VERIFIED" },
              "unit4d": { "const": "CLOSED / ACCEPTED / DIRECTLY VERIFIED" },
              "documentary_authority_cutover": { "const": "CLOSED / ACCEPTED / DIRECTLY VERIFIED" },
              "unit5": { "enum": ["NOT AUTHORIZED / DIAGNOSIS NEXT AUTHORIZABLE", "NOT AUTHORIZED / DIAGNOSIS R2 NEXT AUTHORIZABLE"] }
            }
          },
          "activation": {
            "properties": {
              "status": { "const": "active" },
              "authority_epoch": { "const": 1 },
              "required_parent": { "const": "fa986cf935abbf053172cfd549b0171bb9446f58" },
              "accepted_unit4b_readiness_checkpoint": { "const": "fa986cf935abbf053172cfd549b0171bb9446f58" }
            }
          },
          "rollback_readiness": {
            "properties": {
              "status": { "const": "PREPARED / NOT AUTHORIZED / NOT ACTIVATED" },
              "forward_only": { "const": true }
            }
          },
          "next_authorizable_action": {
            "properties": {
              "order_id": { "enum": ["GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-5-LEGACY-DEPRECATION-AND-POST-CUTOVER-AUDIT-DIAGNOSIS-R1", "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-5-LEGACY-DEPRECATION-AND-POST-CUTOVER-AUDIT-DIAGNOSIS-R2"] },
              "canonical_value": { "enum": ["GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-5-LEGACY-DEPRECATION-AND-POST-CUTOVER-AUDIT-DIAGNOSIS-R1", "GOVERNANCE-EFFICIENCY-REFOUNDATION-UNIT-5-LEGACY-DEPRECATION-AND-POST-CUTOVER-AUDIT-DIAGNOSIS-R2"] },
              "mode": { "const": "READ_ONLY_DIAGNOSIS" },
              "risk_class": { "const": "R1" },
              "status": { "enum": ["AUTHORIZABLE / NOT AUTHORIZED BY THIS CLOSEOUT", "AUTHORIZABLE AFTER DIRECT REVIEW / UNIT 5 IMPLEMENTATION NOT AUTHORIZED"] }
            }
          }
        }
      }
    }
  ]
}
