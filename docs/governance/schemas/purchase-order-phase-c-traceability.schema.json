{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ravatex.local/governance/purchase-order-phase-c-traceability.schema.json",
  "title": "Purchase Order Phase-C traceability shadow",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mode", "authority", "canonical_source", "requirements"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "mode": { "const": "NON_CANONICAL_SHADOW" },
    "authority": { "const": "CANONICAL_MARKDOWN_OWNS_SEMANTICS" },
    "canonical_source": { "const": "docs/architecture/ORDEM_COMPRA_C3_TRACEABILITY.md" },
    "requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["requirement_id", "normative_sources", "disposition", "evidence_pointers", "phase_owner", "blocking_state", "source_location", "canonical_row_sha256", "review_status", "review_basis"],
        "properties": {
          "requirement_id": { "type": "string", "pattern": "^OC-[A-Z0-9-]+$" },
          "normative_sources": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "anchor"],
              "properties": {
                "path": { "type": "string", "pattern": "^docs/.+\\.md$" },
                "anchor": { "type": "string", "minLength": 1 }
              }
            }
          },
          "disposition": { "enum": ["PLANNED", "PARTIALLY_SATISFIED", "SATISFIED", "DEFERRED", "BLOCKED", "NOT_APPLICABLE", "SUPERSEDED"] },
          "evidence_pointers": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "phase_owner": { "type": "string", "minLength": 1 },
          "blocking_state": { "enum": ["BLOCKED", "NON_BLOCKING", "DEFERRED"] },
          "source_location": { "type": "string", "pattern": "^docs/architecture/ORDEM_COMPRA_C3_TRACEABILITY\\.md:\\d+$" },
          "canonical_row_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "review_status": { "const": "REVIEWED" },
          "review_basis": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
