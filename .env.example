GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_TOKEN_PATH=./data/google-token.json

# Storage canônico: Google Drive (mesma conta do Gmail)
# Pasta raiz onde os documentos do ingestor serão organizados no Drive.
# Pode ser informada por nome (será criada) ou por ID já conhecido.
GOOGLE_DRIVE_ROOT_FOLDER_NAME=Ravatex Documents Ingestor
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_CREATE_MISSING_FOLDERS=true

# Cache local — apenas espelho temporário/auxiliar. Nunca fonte canônica.
LOCAL_CACHE_PATH=./data/cache

# Banco e outbox são locais por design.
DATABASE_PATH=./data/app.db
OUTBOX_PATH=./data/outbox/document-events.jsonl
SCAN_DAYS_BACK=7
