GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_TOKEN_PATH=./data/google-token.json

# Escopos OAuth preferenciais (separados por vírgula).
# Default seguro: gmail.readonly + drive.file.
# NUNCA use drive (amplo) sem justificativa explícita.
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/drive.file

# Storage canônico: Google Drive (mesma conta do Gmail)
GOOGLE_DRIVE_ROOT_FOLDER_NAME=Ravatex Documents Ingestor
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_CREATE_MISSING_FOLDERS=true

# Cache local — apenas espelho temporário/auxiliar. Nunca fonte canônica.
LOCAL_CACHE_PATH=./data/cache

# Banco e outbox são locais por design.
DATABASE_PATH=./data/app.db
OUTBOX_PATH=./data/outbox/document-events.jsonl
SCAN_DAYS_BACK=7

# Flag operacional: scan só processa Gmail/Drive real se true.
# Padrão false = dry-run seguro. CLI exige --confirm-real-google.
INGEST_REAL_GOOGLE=false
